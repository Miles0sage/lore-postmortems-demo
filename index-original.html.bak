<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Darwin Postmortem Viewer — Lore</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, monospace;
      background: #0d1117;
      color: #e6edf3;
      padding: 2rem;
      line-height: 1.6;
    }
    header {
      border-bottom: 1px solid #21262d;
      padding-bottom: 1.5rem;
      margin-bottom: 2rem;
    }
    header h1 {
      font-size: 1.8rem;
      color: #58a6ff;
      font-weight: 700;
      letter-spacing: -0.5px;
    }
    header .meta {
      color: #8b949e;
      font-size: 0.85rem;
      margin-top: 0.4rem;
    }
    .stats {
      display: flex;
      gap: 1.5rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }
    .stat-card {
      background: #161b22;
      border: 1px solid #21262d;
      border-radius: 8px;
      padding: 1rem 1.5rem;
      min-width: 140px;
    }
    .stat-card .num {
      font-size: 2rem;
      font-weight: 700;
      color: #58a6ff;
    }
    .stat-card .label {
      font-size: 0.8rem;
      color: #8b949e;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    h2 {
      font-size: 1.2rem;
      color: #e6edf3;
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .count {
      background: #21262d;
      color: #8b949e;
      font-size: 0.8rem;
      padding: 0.1rem 0.5rem;
      border-radius: 20px;
      font-weight: 400;
    }
    .subtitle {
      color: #8b949e;
      font-size: 0.875rem;
      margin-bottom: 1rem;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 2.5rem;
      background: #161b22;
      border: 1px solid #21262d;
      border-radius: 8px;
      overflow: hidden;
      font-size: 0.875rem;
    }
    thead {
      background: #21262d;
    }
    th {
      padding: 0.75rem 1rem;
      text-align: left;
      color: #8b949e;
      font-weight: 600;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }
    th:hover { color: #e6edf3; }
    .sort-icon { color: #30363d; }
    td {
      padding: 0.65rem 1rem;
      border-top: 1px solid #21262d;
      vertical-align: middle;
    }
    tr:hover td { background: #1c2128; }
    code {
      background: #21262d;
      color: #79c0ff;
      padding: 0.1rem 0.4rem;
      border-radius: 4px;
      font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
      font-size: 0.8rem;
    }
    a { color: #58a6ff; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .badge {
      padding: 0.2rem 0.6rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.03em;
    }
    .sev-high { background: #3d1414; color: #f85149; border: 1px solid #f85149; }
    .sev-med  { background: #2d1f00; color: #e3b341; border: 1px solid #e3b341; }
    .sev-low  { background: #112d1f; color: #3fb950; border: 1px solid #3fb950; }
    .kind { font-size: 0.65rem; padding: 0.05rem 0.4rem; margin-left: 0.4rem; border-radius: 3px; vertical-align: middle; letter-spacing: 0.04em; }
    .kind-swap  { background: #0d2818; color: #56d364; }
    .kind-retry { background: #1c1f24; color: #6e7681; }
    .filter-bar { display: flex; align-items: center; gap: 1rem; margin: 0.5rem 0 1rem; padding: 0.6rem 1rem; background: #161b22; border: 1px solid #21262d; border-radius: 6px; font-size: 0.85rem; }
    .filter-bar label { color: #8b949e; cursor: pointer; user-select: none; }
    .filter-bar input[type=checkbox] { accent-color: #58a6ff; transform: translateY(1px); margin-right: 0.4rem; }
    body.hide-retries tr[data-swap='0'] { display: none; }
    .num { text-align: right; font-variant-numeric: tabular-nums; }
    .ts { color: #8b949e; white-space: nowrap; }
    footer {
      color: #30363d;
      font-size: 0.8rem;
      margin-top: 2rem;
      border-top: 1px solid #21262d;
      padding-top: 1rem;
    }
  </style>
</head>
